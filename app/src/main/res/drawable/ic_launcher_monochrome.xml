<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
         Monochrome / Themed icon — the system tints this with the wallpaper colour.
         Strategy: one black filled silhouette covering the full mole+hat+claws shape,
         then white cutouts to carve in the key details (eyes, snout, hat brim gap).
         This keeps the character readable in any tint without relying on colour.
    -->

    <!-- ── FULL OUTER SILHOUETTE (claws + body + hat dome + brim) ── -->

    <!-- Left claw -->
    <path
        android:fillColor="#000000"
        android:pathData="M30,66 Q22,58 13,57 Q7,55 4,60 Q2,66 6,70 Q4,75 8,77 Q7,82 11,80 Q15,84 19,79 Q24,82 28,76 Z"/>

    <!-- Right claw -->
    <path
        android:fillColor="#000000"
        android:pathData="M78,66 Q86,58 95,57 Q101,55 104,60 Q106,66 102,70 Q104,75 100,77 Q101,82 97,80 Q93,84 89,79 Q84,82 80,76 Z"/>

    <!-- Body + head -->
    <path
        android:fillColor="#000000"
        android:pathData="M38,46 Q28,58 26,74 Q24,90 38,96 Q54,100 70,96 Q84,90 82,74 Q80,58 70,46 Q62,34 54,34 Q46,34 38,46 Z"/>

    <!-- Hat dome -->
    <path
        android:fillColor="#000000"
        android:pathData="M32,44 Q30,20 54,16 Q78,20 76,44 Z"/>

    <!-- Hat brim (slightly wider) -->
    <path
        android:fillColor="#000000"
        android:pathData="M22,44 L86,44 L88,54 L20,54 Z"/>

    <!-- ── WHITE CUTOUTS carve internal details into the silhouette ── -->

    <!-- Snout — white teardrop with an even-odd inner outline so the snout
         reads as a lighter area rather than a void -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M44,56 Q42,74 54,82 Q66,74 64,56 Q64,48 54,46 Q44,48 44,56 Z
                          M47,57 Q47,52 54,50 Q61,52 61,57 Q61,72 54,78 Q47,72 47,57 Z"/>

    <!-- Left eye -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M43,53 A3.5,3 0 1,0 50,53 A3.5,3 0 1,0 43,53 Z"/>

    <!-- Right eye -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M58,53 A3.5,3 0 1,0 65,53 A3.5,3 0 1,0 58,53 Z"/>

    <!-- Hat brim separation gap — thin white sliver between dome and brim
         so the two shapes read as distinct at small sizes -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,43 L78,43 L78,45 L30,45 Z"/>

</vector>
